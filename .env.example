# ForkFlow configuration
# Copy to .env and edit before running: cp .env.example .env

# Credentials (used only before first-run setup via web UI)
FORKFLOW_USERNAME=admin
FORKFLOW_PASSWORD=changeme

# Encryption key for provider API keys at rest
# Optional — auto-generated on first run if left empty
# Generate manually: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FORKFLOW_ENCRYPTION_KEY=

# SQLite database path (inside container, mounted from ./data)
FORKFLOW_DB_PATH=/data/forkflow.db

# Sandbox directory for tool execution (inside container, mounted from ./data)
FORKFLOW_SANDBOX_DIR=/data/sandbox

# Server
FORKFLOW_HOST=0.0.0.0
FORKFLOW_PORT=8000

# Max concurrent provider API calls
FORKFLOW_MAX_CONCURRENT_PROVIDER_CALLS=5
